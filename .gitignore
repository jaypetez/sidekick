# Secrets — never commit these
.env
.env.*
!.env.example
credentials.json
token.json

# Secret-bearing files this repo's tooling and personal-machine helpers
# may produce. Catch-all: anything ending in -creds.json, -secrets.json,
# or .secret(s).
*.secret
*.secrets
*secrets.json
*-creds.json
.chronary-*
.azure-*
.keyvault-*
.kv-*.json
auth.json
api-keys.json

# Private key material
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Type checking
.mypy_cache/

# IDE
.idea/
.vscode/
*.swp

# Logs
*.log

# Smoke-test artifacts (scripts/smoke_test_web_only.py)
.smoke-*

# Example data dirs created by docker compose
data/

# Generated screenshots — kept out of git unless explicitly committed.
# Remove this exclusion if you regenerate via scripts/capture_screenshots.py
# and want to ship them in the README.
# docs/screenshots/*.png
