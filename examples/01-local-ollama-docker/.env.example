# Example 01 — local Ollama via Docker, web UI as the only chat surface.
# Copy this file to the repo root as `.env` (overwriting the default), then
# fill in the Chronary section before starting the stack.

# Telegram — INTENTIONALLY BLANK. No token → bot starts in web-only mode and
# the in-process dashboard at http://localhost:8080/chat becomes the chat UI.
TELEGRAM_BOT_TOKEN=

# LLM provider — local Ollama (no Anthropic key needed for this example).
LLM_PROVIDER=ollama

# Docker network: sidekick → ollama by service name.
OLLAMA_BASE_URL=http://ollama:11434

# qwen2.5:14b: ~9GB on disk, fits comfortably in 16GB VRAM (Q4 ~ 9GB GPU memory).
# Materially better tool-calling than 7-8b models — recommended for this example.
# If you have <12GB VRAM, drop to qwen2.5:7b or llama3.1:8b (also <6GB).
OLLAMA_MODEL=qwen2.5:14b

# Chronary.ai calendar — STILL REQUIRED.
# Even in web-only mode the bot expects a calendar backend; calendar features
# (and the /events page) will 503 without it. Get a key from
# https://console.chronary.ai, then run `sidekick-init` once to mint the agent
# + calendar IDs (see the README).
CHRONARY_API_KEY=chr_ak_replace_me
CHRONARY_AGENT_ID=agt_replace_after_init
CHRONARY_CALENDAR_ID=cal_replace_after_init

# Bind the web UI on 0.0.0.0 INSIDE the container so the host browser can reach it
# via the published port. The container is firewalled by Docker; this does not
# expose the dashboard to your LAN unless you forward the port further.
#
# Because we bind to 0.0.0.0 (non-loopback), the bot REQUIRES a bearer token —
# generate a strong random value and put it in SIDEKICK_WEB_AUTH_TOKEN below.
# On *nix:    python -c "import secrets; print(secrets.token_urlsafe(32))"
# On Windows: -join ((48..57)+(97..122)+(65..90) | Get-Random -Count 48 | %{[char]$_})
# Every dashboard request must then carry `Authorization: Bearer <token>`.
SIDEKICK_WEB_ENABLED=true
SIDEKICK_WEB_HOST=0.0.0.0
SIDEKICK_WEB_PORT=8080
SIDEKICK_WEB_AUTH_TOKEN=replace_me_with_a_strong_random_string

# Timezone — set to wherever you live.
TIMEZONE=America/Chicago

# Reminders are Telegram-only today and won't fire in this example. Leave
# blank — they're not needed to exercise chat/tasks/calendar.
REMINDER_CHAT_ID=
