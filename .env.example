# Sidekick environment configuration.
#
# SECURITY: this file holds bot tokens, API keys, and a chat id. After
# copying to `.env`, restrict permissions so other users on the host
# cannot read your secrets:
#
#     chmod 0600 .env
#
# For a stronger posture, push the secret-bearing values to Azure Key
# Vault and use scripts/run-with-kv.ps1 to load them into the bot's
# environment at runtime — see docs/secrets-azure-keyvault.md.
#
# The optional web dashboard auth token and other deployment hardening
# notes live in docs/security.md (see the "Deployment posture" section of
# README.md for a summary).

# Telegram — get from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Closed-by-default user allowlist. CSV of numeric Telegram user IDs that
# are permitted to talk to the bot. **If this is unset or empty, the bot
# rejects every incoming message.** Use @userinfobot in Telegram to find
# a user id.
# TELEGRAM_ALLOWED_USER_IDS=12345678,98765432

# Target chat ID for reminders — send /get_id in the chat to find this
REMINDER_CHAT_ID=your_group_chat_id_here

# Slack (optional) — set both to enable the Slack adapter alongside Telegram.
# Bot Token Scopes needed: chat:write, app_mentions:read, im:history, im:read, im:write.
# Enable Socket Mode and generate an app-level token.
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token

# Closed-by-default Slack user allowlist. CSV of Slack user IDs (e.g.
# U01ABC23DEF). **If unset/empty, the Slack adapter rejects every
# message.** Optional channel allowlist further restricts which channels
# the bot will respond in; unset = all channels the bot user can see.
# SLACK_ALLOWED_USER_IDS=U01ABC23DEF,U07XYZ98QPR
# SLACK_ALLOWED_CHANNELS=C0123456789

# Per-user/per-session rate limit shared by Telegram, Slack, and the web
# /chat endpoint. Defaults to 10 requests per 60s window.
# SIDEKICK_RATE_LIMIT_MAX=10
# SIDEKICK_RATE_LIMIT_WINDOW_SECONDS=60

# LLM provider — "anthropic" (default) or "ollama" (local).
LLM_PROVIDER=anthropic

# Anthropic — get from console.anthropic.com (required when LLM_PROVIDER=anthropic).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (required when LLM_PROVIDER=ollama). Use a tool-capable model.
# Recommended: llama3.1:8b or qwen2.5:7b. Smaller models will misfire on
# multi-tool plans; tool-use is materially less reliable than Claude.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Chronary.ai calendar — get from console.chronary.ai
CHRONARY_API_KEY=chr_ak_your_agent_key_here
# Set by `sidekick-init` on first run. After running it, paste the
# printed values here (or rely on ~/.config/sidekick/config.json).
CHRONARY_AGENT_ID=agt_replace_after_init
CHRONARY_CALENDAR_ID=cal_replace_after_init

# Local SQLite store for tasks/groceries (override only if needed)
# SIDEKICK_DB_PATH=~/.config/sidekick/sidekick.db

# Timezone (IANA format, e.g. America/Chicago, America/New_York, America/Los_Angeles)
TIMEZONE=America/Chicago

# Morning summary time (24h HH:MM)
MORNING_REMINDER_TIME=07:30

# Minutes before an event to send a reminder (set to 0 to disable)
PRE_EVENT_REMINDER_MINUTES=30

# Claude model
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Web admin dashboard — runs in-process alongside Telegram/Slack.
# Defaults bind to localhost only so the dashboard isn't exposed.
# Set SIDEKICK_WEB_ENABLED=false to skip it (Docker, CI, headless servers).
SIDEKICK_WEB_ENABLED=true
SIDEKICK_WEB_HOST=127.0.0.1
SIDEKICK_WEB_PORT=8080

# Optional bearer token for the dashboard. Leave unset for the default
# loopback-only deployment. REQUIRED when SIDEKICK_WEB_HOST is anything
# other than 127.0.0.1 / localhost / ::1 — the bot will refuse to bind
# a non-loopback interface without it. Use a long random string:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# SIDEKICK_WEB_AUTH_TOKEN=

# Optional secret for signing the dashboard's session cookie. If unset,
# a fresh 32-byte secret is generated and persisted to
# ${SIDEKICK_CONFIG_DIR}/web_session.secret with mode 0600 on first run.
# Set this explicitly only if you need cookies to survive a config-dir
# wipe (e.g. ephemeral container with mounted secret).
# SIDEKICK_WEB_SESSION_SECRET=
